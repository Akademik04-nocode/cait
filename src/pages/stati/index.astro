---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
---

<BaseLayout
  title="Статьи - Квазар"
  description="Полезные статьи о строительных материалах, теплоизоляции и подвесных потолках."
>
  <Breadcrumbs items={[{ title: 'Главная', href: '/' }, { title: 'Статьи', href: '/stati/' }]} />
  <h1 class="text-2xl font-bold text-brand-primary-900 mb-6">Статьи</h1>
  <div class="space-y-6">
    {allArticles.map((entry) => (
      <article class="rounded-lg border border-slate-200 bg-white p-5 hover:shadow-sm transition">
        <a href={`/stati/${entry.slug}/`} class="block">
          <h2 class="text-lg font-semibold text-brand-primary-800 hover:text-brand-accent-600">
            {entry.data.title}
          </h2>
          {entry.data.excerpt && (
            <p class="mt-2 text-sm text-slate-600">{entry.data.excerpt}</p>
          )}
        </a>
      </article>
    ))}
  </div>
</BaseLayout>
