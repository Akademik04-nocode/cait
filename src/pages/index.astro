---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCategories = await getCollection('categories');
const topLevelCategories = allCategories.filter(
  (c) => !c.data.parent && c.data.slug !== 'katalog'
);

const allBrands = await getCollection('brands');
const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  })
  .slice(0, 3);

const allObjects = await getCollection('objects');
const featuredObjects = allObjects.slice(0, 4);

const advantages = [
  { title: 'С 2007 года', desc: 'Более 17 лет на рынке', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { title: 'Склад в СПб', desc: 'Товары в наличии', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { title: 'Доставка', desc: 'По Северо-Западу', icon: 'M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0' },
  { title: 'Объекты', desc: 'Госзаказы и бизнес', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { title: 'Сертификаты', desc: 'Официальный дилер', icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' },
  { title: '100+ позиций', desc: 'Широкий ассортимент', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
];

// Category icons by slug
const categoryIcons: Record<string, string> = {
  potolki_i_steni: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  teploizolyatsiya: 'M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z',
  drevesno_plitnie_materiali: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z',
  stroitelnie_smesi_vetonit: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  gipsovie_stroitelnie_pliti: 'M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2',
  revizionnie_lyuki: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
};
---

<BaseLayout
  title="Квазар. Подвесные потолки и теплоизоляция в Санкт-Петербурге"
  description="Квазар - поставка подвесных потолков, теплоизоляции, OSB, Vetonit и гипсокартона в Санкт-Петербурге. Работаем с объектами и частными заказчиками."
  image="/og-image.svg"
>
  <!-- Hero -->
  <section class="relative -mx-4 -mt-8 overflow-hidden bg-gradient-to-br from-brand-primary-800 via-brand-primary-700 to-brand-primary-900 px-4 text-white sm:-mx-4 md:-mx-4">
    <!-- Decorative shapes -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-white/5"></div>
      <div class="absolute -bottom-32 -left-16 w-80 h-80 rounded-full bg-brand-accent-500/10"></div>
      <div class="absolute top-1/2 right-1/4 w-64 h-64 rounded-full bg-white/5"></div>
    </div>
    <div class="container relative py-16 md:py-24 lg:py-32">
      <p class="inline-block rounded-full bg-white/10 px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-white/80 mb-6">
        с 2007 года &middot; Санкт-Петербург
      </p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 max-w-4xl">
        Строительные материалы
        <span class="text-brand-accent-400"> напрямую от производителей</span>
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-white/80 mb-8 max-w-2xl leading-relaxed">
        Подвесные потолки, теплоизоляция, OSB, Vetonit и гипсокартон со склада в Санкт-Петербурге. Поставляем материалы на объекты по всему Северо-Западу.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/katalog/" class="inline-flex items-center px-6 py-3 bg-brand-accent-500 hover:bg-brand-accent-600 rounded-lg font-semibold text-white shadow-lg shadow-brand-accent-500/25 transition-all hover:-translate-y-0.5">
          Перейти в каталог
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/kontakty/" class="inline-flex items-center px-6 py-3 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg font-semibold text-white transition-all hover:-translate-y-0.5">
          Связаться с нами
        </a>
      </div>
    </div>
  </section>

  <!-- Advantages -->
  <section class="py-12 md:py-16">
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
      {advantages.map((item) => (
        <div class="flex flex-col items-center text-center p-4 rounded-xl hover:bg-brand-primary-50 transition-colors">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-accent-100 text-brand-accent-600 mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-slate-900">{item.title}</h3>
          <p class="text-xs text-slate-500 mt-0.5">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section class="py-8 md:py-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Каталог продукции</h2>
      <a href="/katalog/" class="text-sm font-medium text-brand-primary-700 hover:text-brand-accent-600 transition-colors hidden sm:block">
        Все категории &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {topLevelCategories.map((cat) => {
        const iconPath = categoryIcons[cat.data.slug] || 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6z';
        return (
          <a
            href={`/katalog/${cat.data.slug}/`}
            class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-brand-primary-700 to-brand-primary-900 p-6 md:p-8 text-white min-h-[180px] flex flex-col justify-between transition-all hover:shadow-xl hover:-translate-y-1"
          >
            <div class="absolute top-4 right-4 opacity-10 group-hover:opacity-20 transition-opacity">
              <svg class="w-24 h-24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d={iconPath} />
              </svg>
            </div>
            <div class="relative z-10">
              <svg class="w-8 h-8 text-brand-accent-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconPath} />
              </svg>
            </div>
            <div class="relative z-10">
              <h3 class="text-lg md:text-xl font-bold mb-1">{cat.data.title}</h3>
              <span class="text-sm text-white/60 group-hover:text-brand-accent-300 transition-colors">
                Смотреть каталог &rarr;
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Brands -->
  <section class="py-8 md:py-12">
    <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-6">Наши бренды</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      {allBrands.slice(0, 15).map((brand) => (
        <div class="flex items-center justify-center h-16 md:h-20 rounded-xl border border-slate-200 bg-white hover:border-brand-accent-400 hover:shadow-md transition-all cursor-default">
          <span class="text-sm md:text-base font-bold text-brand-primary-800 text-center px-2">{brand.data.title}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Objects / Portfolio -->
  {featuredObjects.length > 0 && (
    <section class="py-8 md:py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Наши объекты</h2>
        <a href="/obekty/" class="text-sm font-medium text-brand-primary-700 hover:text-brand-accent-600 transition-colors hidden sm:block">
          Все объекты &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {featuredObjects.map((obj) => (
          <a
            href={`/obekty/${obj.slug}/`}
            class="group block overflow-hidden rounded-xl border border-slate-200 bg-white hover:shadow-lg transition-all hover:-translate-y-0.5"
          >
            <div class="aspect-[4/3] bg-gradient-to-br from-brand-primary-100 to-brand-primary-200 flex items-center justify-center">
              <svg class="w-12 h-12 text-brand-primary-400 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div class="p-4">
              <h3 class="text-sm font-semibold text-slate-900 group-hover:text-brand-primary-700 transition-colors line-clamp-2">
                {obj.data.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- News -->
  <section class="py-8 md:py-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Новости</h2>
      <a href="/novosti/" class="text-sm font-medium text-brand-primary-700 hover:text-brand-accent-600 transition-colors hidden sm:block">
        Все новости &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
      {latestNews.map((entry) => (
        <a
          href={`/novosti/${entry.slug}/`}
          class="group block rounded-xl border border-slate-200 bg-white p-5 md:p-6 hover:shadow-lg hover:border-brand-primary-200 transition-all hover:-translate-y-0.5"
        >
          {entry.data.date && (
            <time class="text-xs font-medium text-brand-accent-600" datetime={entry.data.date.toISOString()}>
              {entry.data.date.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          )}
          <h3 class="mt-2 text-base font-bold text-slate-900 group-hover:text-brand-primary-700 transition-colors">
            {entry.data.title}
          </h3>
          {entry.data.excerpt && (
            <p class="mt-2 text-sm text-slate-500 line-clamp-2">{entry.data.excerpt}</p>
          )}
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-8 md:py-12">
    <div class="rounded-2xl bg-gradient-to-br from-brand-primary-50 to-brand-primary-100 p-8 md:p-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-primary-900 mb-3">Нужна консультация?</h2>
      <p class="text-slate-700 mb-6 max-w-lg mx-auto">
        Позвоните нам или оставьте заявку. Менеджер перезвонит в течение 15 минут в рабочее время.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:+78124572106"
          class="inline-flex items-center px-6 py-3 bg-brand-primary-800 hover:bg-brand-primary-900 text-white rounded-lg font-semibold shadow-lg shadow-brand-primary-800/20 transition-all hover:-translate-y-0.5"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          +7 (812) 457-21-06
        </a>
        <a
          href="mailto:info@kvazarcomp.ru"
          class="inline-flex items-center px-6 py-3 border-2 border-brand-primary-800 text-brand-primary-800 hover:bg-brand-primary-800 hover:text-white rounded-lg font-semibold transition-all"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          info@kvazarcomp.ru
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
