---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allObjects = await getCollection('objects');
---

<BaseLayout
  title="Объекты - Квазар"
  description="Объекты, на которые ООО Квазар осуществлял поставки строительных материалов."
>
  <Breadcrumbs items={[{ title: 'Главная', href: '/' }, { title: 'Объекты', href: '/obekty/' }]} />
  <h1 class="text-2xl font-bold text-brand-primary-900 mb-6">Наши объекты</h1>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
    {allObjects.map((entry) => (
      <a
        href={`/obekty/${entry.slug}/`}
        class="block rounded-lg border border-slate-200 bg-white p-5 hover:shadow-sm transition"
      >
        <h2 class="text-base font-semibold text-brand-primary-800 hover:text-brand-accent-600">
          {entry.data.title}
        </h2>
        {entry.data.excerpt && (
          <p class="mt-2 text-sm text-slate-600">{entry.data.excerpt}</p>
        )}
        {entry.data.location && (
          <p class="mt-1 text-xs text-slate-500">{entry.data.location}</p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
