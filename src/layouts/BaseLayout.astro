---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Квазар. Подвесные потолки, теплоизоляция, OSB, Vetonit и гипсокартон в Санкт-Петербурге.', image } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://kvazarcomp.ru').toString();
const ogImage = image ? new URL(image, Astro.site ?? 'https://kvazarcomp.ru').toString() : undefined;

const orgJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Квазар',
  url: 'https://kvazarcomp.ru',
  logo: 'https://kvazarcomp.ru/images/logo.png',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+7 (812) 457-21-06',
    contactType: 'sales',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Митрофаньевское шоссе, д.17 к.2Б',
    addressLocality: 'Санкт-Петербург',
    postalCode: '198095',
    addressCountry: 'RU',
  },
});
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={orgJsonLd} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-2 focus:bg-white focus:text-brand-primary-800">
      Перейти к содержимому
    </a>
    <Header />
    <main id="main-content" class="flex-1 container py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
