---
interface Props {
  product?: string;
}

const { product } = Astro.props;
const formEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT || '';
const formAction = formEndpoint || 'mailto:info@kvazarcomp.ru';
const isMailto = !formEndpoint;
---

<form
  action={formAction}
  method={isMailto ? 'GET' : 'POST'}
  class="space-y-4 rounded-lg border border-slate-200 bg-slate-50 p-6"
  data-product={product}
  data-mailto={isMailto ? 'true' : undefined}
>
  <h3 class="text-lg font-semibold text-brand-primary-800">Запросить цену</h3>
  {product && <input type="hidden" name="product" value={product} />}
  <div>
    <label for="cf-name" class="block text-sm font-medium text-slate-700">Имя</label>
    <input
      type="text"
      id="cf-name"
      name="name"
      required
      class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-brand-primary-500 focus:ring-1 focus:ring-brand-primary-500"
    />
  </div>
  <div>
    <label for="cf-phone" class="block text-sm font-medium text-slate-700">Телефон</label>
    <input
      type="tel"
      id="cf-phone"
      name="phone"
      required
      class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-brand-primary-500 focus:ring-1 focus:ring-brand-primary-500"
    />
  </div>
  <div>
    <label for="cf-email" class="block text-sm font-medium text-slate-700">Email</label>
    <input
      type="email"
      id="cf-email"
      name="email"
      class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-brand-primary-500 focus:ring-1 focus:ring-brand-primary-500"
    />
  </div>
  <div>
    <label for="cf-message" class="block text-sm font-medium text-slate-700">Сообщение</label>
    <textarea
      id="cf-message"
      name="message"
      rows="3"
      class="mt-1 block w-full rounded border border-slate-300 px-3 py-2 text-sm focus:border-brand-primary-500 focus:ring-1 focus:ring-brand-primary-500"
    ></textarea>
  </div>
  <button
    type="submit"
    class="rounded bg-brand-accent-600 px-6 py-2 text-sm font-semibold text-white hover:bg-brand-accent-700 transition"
  >
    Отправить
  </button>
  <p class="cf-mailto-msg hidden text-sm text-green-700 font-medium"></p>
</form>

<script>
  document.querySelectorAll('form[data-mailto="true"]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const f = e.currentTarget as HTMLFormElement;
      const name = (f.querySelector('[name="name"]') as HTMLInputElement)?.value || '';
      const phone = (f.querySelector('[name="phone"]') as HTMLInputElement)?.value || '';
      const email = (f.querySelector('[name="email"]') as HTMLInputElement)?.value || '';
      const message = (f.querySelector('[name="message"]') as HTMLTextAreaElement)?.value || '';
      const product = (f.querySelector('[name="product"]') as HTMLInputElement)?.value || '';

      const subject = encodeURIComponent(product ? `Запрос: ${product}` : 'Запрос с сайта');
      const body = encodeURIComponent(
        `Имя: ${name}\nТелефон: ${phone}\nEmail: ${email}\n\n${message}`
      );
      window.location.href = `mailto:info@kvazarcomp.ru?subject=${subject}&body=${body}`;

      const msg = f.querySelector('.cf-mailto-msg') as HTMLElement;
      if (msg) {
        msg.textContent = 'Откройте почтовый клиент для отправки сообщения';
        msg.classList.remove('hidden');
      }
    });
  });
</script>
