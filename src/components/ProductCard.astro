---
interface Props {
  title: string;
  slug: string;
  brand?: string;
  priceLabel?: string;
  image?: string;
}

const { title, slug, brand, priceLabel, image } = Astro.props;
---

<a
  href={`/katalog/${slug}/`}
  class="group block rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition hover:shadow-md hover:border-brand-primary-200"
>
  <div class="aspect-square w-full overflow-hidden rounded bg-slate-100 mb-3">
    {image ? (
      <img
        src={image}
        alt={title}
        class="h-full w-full object-contain transition group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
  </div>
  <h3 class="text-sm font-semibold text-slate-800 line-clamp-2 group-hover:text-brand-primary-700">
    {title}
  </h3>
  {brand && <p class="mt-1 text-xs text-slate-500">{brand}</p>}
  {priceLabel && <p class="mt-1 text-xs font-medium text-brand-accent-700">{priceLabel}</p>}
</a>
